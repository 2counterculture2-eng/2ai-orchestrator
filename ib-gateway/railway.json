{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "ib-gateway/Dockerfile"
  },
  "deploy": {
    "startCommand": null,
    "healthcheckPath": "/v1/api/tickle",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
