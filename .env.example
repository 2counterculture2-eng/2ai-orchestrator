# ============================================================
# 2AI Orchestrator v1 — Environment Variables
# Copy this file to .env for local dev (never commit .env)
# On Railway: set these in the dashboard → Variables tab
# ============================================================

# ---- REQUIRED ----
ANTHROPIC_API_KEY=sk-ant-...          # Anthropic Console → API Keys

# ---- LINE Bot (required for reports) ----
LINE_CHANNEL_ACCESS_TOKEN=...         # LINE Developers → Messaging API → Channel access token
LINE_CHANNEL_SECRET=...               # LINE Developers → Messaging API → Channel secret
LINE_USER_ID=U...                     # Your LINE user ID (get from webhook events)

# ---- Alpaca (US stocks — paper trading by default) ----
ALPACA_API_KEY=...
ALPACA_SECRET_KEY=...
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # switch to https://api.alpaca.markets for live

# ---- OANDA (FX) ----
OANDA_API_KEY=...
OANDA_ACCOUNT_ID=...
OANDA_ENVIRONMENT=practice            # practice → live after verification

# ---- Smartcat (translation) ----
SMARTCAT_API_KEY=...                  # base64(accountId:apiKey) from Smartcat dashboard
SMARTCAT_ACCOUNT_ID=...

# ---- Upwork via GigRadar ----
GIGRADAR_API_KEY=...

# ---- App settings (optional, defaults shown) ----
PORT=8000
LOG_LEVEL=INFO
DB_PATH=/app/data/orchestrator.db     # Railway persistent volume path
WEEKLY_REPORT_DAY=0                   # 0=Monday
WEEKLY_REPORT_HOUR=9                  # 09:00 JST
MAX_MONTHLY_CLAUDE_COST=10.0
MAX_MONTHLY_INFRA_COST=10.0

# ---- Model overrides (optional) ----
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001
CLAUDE_SONNET_MODEL=claude-sonnet-4-6
CLAUDE_OPUS_MODEL=claude-opus-4-8
